{
  "name": "cf-ingress-controller",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/cf-ingress-controller/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/cf-ingress-controller",
        "main": "apps/cf-ingress-controller/src/main.ts",
        "tsConfig": "apps/cf-ingress-controller/tsconfig.app.json",
        "assets": []
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/cf-ingress-controller/jest.config.ts"
      }
    }
  }
}
