{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 0,
  "minimumReleaseAge": "14 days",
  "internalChecksFilter": "strict",
  "labels": ["dependencies"],
  "postUpdateOptions": ["pnpmDedupe"],
  "automergeType": "pr",
  "separateMultipleMajor": true,
  "timezone": "Europe/Berlin",
  "npmrc": "frozen-lockfile=false",
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "matchManagers": ["helmv3"],
      "matchFileNames": ["platform/services/monitoring/Chart.yaml"],
      "groupName": "monitoring sub-charts"
    },
    {
      "matchManagers": ["helmv3"],
      "matchFileNames": [
        "platform/core/github-arc-runners/controller/Chart.yaml",
        "platform/core/github-arc-runners/runners/Chart.yaml"
      ],
      "groupName": "github-arc-runners sub-charts"
    },
    {
      "matchManagers": ["helmv3"],
      "matchFileNames": ["platform/core/hetzner-cloud-controller/Chart.yaml"],
      "groupName": "hetzner-cloud-controller sub-charts"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["templates/.*\\.yaml$"],
      "matchStrings": ["image:\\s*(?<depName>[^:]+):(?<currentValue>[^\\s\"]+)"],
      "datasourceTemplate": "docker"
    }
  ]
}
