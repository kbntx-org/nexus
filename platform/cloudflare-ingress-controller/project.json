{
  "name": "cloudflare-ingress-controller",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "platform/cloudflare-ingress-controller/src",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "platform": "node",
        "outputPath": "dist/platform/cloudflare-ingress-controller",
        "main": "platform/cloudflare-ingress-controller/src/main.ts",
        "tsConfig": "platform/cloudflare-ingress-controller/tsconfig.app.json",
        "bundle": true,
        "format": ["cjs"],
        "thirdParty": true
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "platform/cloudflare-ingress-controller/jest.config.ts"
      }
    }
  }
}
