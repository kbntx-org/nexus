{
  "name": "cloudflare-ingress-controller",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "platform/cloudflare-ingress-controller",
  "tags": ["lang:go", "platform"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go build -o dist/cloudflare-ingress-controller ./cmd/",
        "cwd": "platform/cloudflare-ingress-controller"
      },
      "outputs": ["{workspaceRoot}/platform/cloudflare-ingress-controller/dist"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go test ./...",
        "cwd": "platform/cloudflare-ingress-controller"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go vet ./...",
        "cwd": "platform/cloudflare-ingress-controller"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t cloudflare-ingress-controller:latest .",
        "cwd": "platform/cloudflare-ingress-controller"
      }
    }
  }
}
